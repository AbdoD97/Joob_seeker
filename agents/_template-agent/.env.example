# Anthropic API (for job scoring/analysis)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-xxxxx
TELEGRAM_CHAT_ID=123456789

# Job Search Config
SEARCH_KEYWORDS=automation engineer
SEARCH_LOCATION=Netherlands
RESULTS_PER_RUN=50
SCORE_THRESHOLD=6

# Optional: comma-separated list of must-have keywords for scoring boost
PREFERRED_SKILLS=Python,PLC,SCADA,TwinCAT

# Optional: comma-separated list of companies to exclude
EXCLUDED_COMPANIES=

# Schedule (hours between runs)
SCHEDULE_INTERVAL_HOURS=6
